# Declare the default behavior to handle all files as text and detect line endings automatically
* text=auto

# Explicitly set eol to lf for text files to avoid Wails generator creating CRLF mismatches
*.go text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.ico binary
*.svg text eol=lf
